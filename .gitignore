# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node / Next.js (Frontend)
**/node_modules/
**/.next/
**/out/
**/build/
frontend/.env*.local
frontend/.env*.development.local
frontend/.env*.test.local
frontend/.env*.production.local

# Python / FastAPI (Backend)
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.pytest_cache/
backend/venv/
backend/.venv/
backend/env/
backend/.env
backend/uploads/*
backend/outputs/*
backend/temp/*
!backend/uploads/.gitkeep
!backend/outputs/.gitkeep
!backend/temp/.gitkeep

# IDEs & System files
.DS_Store
.vscode/
.idea/
*.pem
*.tsbuildinfo
next-env.d.ts

# debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
